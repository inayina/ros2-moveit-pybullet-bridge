<?xml version="1.0"?>
<robot name="planar_2dof_arm">
  <!-- Planar 2-DOF arm in the XZ plane (joints rotate about Y), mounted on a pedestal. -->

  <material name="pedestal_dark">
    <color rgba="0.35 0.35 0.38 1.0"/>
  </material>
  <material name="base_gray">
    <color rgba="0.5 0.5 0.55 1.0"/>
  </material>
  <material name="link_orange">
    <color rgba="0.95 0.45 0.10 1.0"/>
  </material>
  <material name="link_blue">
    <color rgba="0.15 0.45 0.85 1.0"/>
  </material>
  <material name="ee_green">
    <color rgba="0.10 0.80 0.25 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.22" rpy="0 0 0"/>
      <geometry><box size="0.14 0.14 0.44"/></geometry>
      <material name="pedestal_dark"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.46" rpy="0 0 0"/>
      <geometry><box size="0.16 0.16 0.04"/></geometry>
      <material name="base_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.22" rpy="0 0 0"/>
      <geometry><box size="0.14 0.14 0.44"/></geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.46" rpy="0 0 0"/>
      <geometry><box size="0.16 0.16 0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.24" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <geometry><box size="0.30 0.06 0.06"/></geometry>
      <material name="link_orange"/>
    </visual>
    <collision>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <geometry><box size="0.30 0.06 0.06"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.48" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.4" upper="2.4" effort="100" velocity="2.0"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.05 0.05"/></geometry>
      <material name="link_blue"/>
    </visual>
    <collision>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry><box size="0.25 0.05 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.30 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="80" velocity="2.0"/>
  </joint>

  <link name="tool0">
    <visual>
      <geometry><sphere radius="0.035"/></geometry>
      <material name="ee_green"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.035"/></geometry>
    </collision>
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link2"/>
    <child link="tool0"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
  </joint>
</robot>
